# moodful_responder — environment template.
#
# Copy this to `.env` (which is gitignored) and fill in your values:
#     cp example.env .env
# The CLI auto-loads `.env` from the current directory or the repo root, so no
# `source` is needed. Real environment variables take precedence over the file.

# --- Required for `review` (the step that posts) ---------------------------
# Your Bluesky handle (or account email). This is the identity replies post from.
BSKY_IDENTIFIER=your-handle.bsky.social

# An APP PASSWORD — not your real password.
# Generate one: Bluesky -> Settings -> Privacy and security -> App passwords.
# Format looks like: xxxx-xxxx-xxxx-xxxx
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Required for `relay` (approve from your phone via Telegram) -----------
# Create a bot: in Telegram, message @BotFather -> /newbot -> copy the token.
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...

# The chat the bot talks to (you). Leave blank, send your bot any message, then
# run `relay` once — it prints the chat id to paste back here.
TELEGRAM_CHAT_ID=

# --- Optional --------------------------------------------------------------
# PDS host. Only change if the account lives on a custom PDS (not bsky.social).
BSKY_PDS=https://bsky.social

# Where the queue/state SQLite file is kept.
MOODFUL_RESPONDER_DB=responder.db
